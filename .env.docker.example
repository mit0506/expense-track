# Copy this file to .env.docker and fill in real values
# NEVER commit .env.docker to version control

# MySQL
MYSQL_DATABASE=expense_tracker
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_USER=expense_user
MYSQL_PASSWORD=CHANGE_ME_db_password

# Flask App
DATABASE_URL=mysql+pymysql://expense_user:CHANGE_ME_db_password@db:3306/expense_tracker
SECRET_KEY=CHANGE_ME_generate_with_python_secrets
FLASK_ENV=production
